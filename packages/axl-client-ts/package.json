{
  "name": "@anton/axl-client",
  "version": "0.0.0",
  "private": true,
  "description": "Reusable TypeScript client for the AXL HTTP bridge (127.0.0.1:9002).",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
