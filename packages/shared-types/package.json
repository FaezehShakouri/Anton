{
  "name": "@anton/shared-types",
  "version": "0.0.0",
  "private": true,
  "description": "TypeScript types shared between the Tauri Rust IPC surface and the Anton UI.",
  "type": "module",
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b --noEmit"
  },
  "devDependencies": {
    "typescript": "^6.0.0"
  }
}
