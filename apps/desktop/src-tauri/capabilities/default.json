{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities granted to the main Anton window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:event:default",
    "shell:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "axl",
          "sidecar": true,
          "args": [
            "--config",
            { "validator": "\\S+" }
          ]
        }
      ]
    }
  ]
}
